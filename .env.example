# ── Chassis configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in what you need.
# Every integration below is OPT-IN: leave a variable empty (or delete
# the line) and the matching module simply never loads.

NODE_ENV=development
PORT=8000

# Comma-separated list of allowed CORS origins.
# Leave empty to allow all origins (fine for local dev, lock down in prod).
CORS_ORIGINS=

# ── MongoDB (optional) ──────────────────────────────── chassis:mongo
# Setting MONGODB_URI enables the Mongo integration.     # chassis:mongo
MONGODB_URI=                                             # chassis:mongo

# ── Auth0 (optional) ────────────────────────────────── chassis:auth0
# Setting BOTH values enables JWT auth on @protectedRoute. # chassis:auth0
AUTH0_DOMAIN=                                            # chassis:auth0
AUTH0_AUDIENCE=                                          # chassis:auth0

# ── Sentry (optional) ──────────────────────────────── chassis:sentry
# Setting SENTRY_DSN enables error reporting to Sentry.  # chassis:sentry
SENTRY_DSN=                                              # chassis:sentry
