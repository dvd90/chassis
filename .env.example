# ── Chassis configuration ──────────────────────────────────────────
# Copy this file to `.env` and fill in what you need.
# Every integration below is OPT-IN: leave a variable empty (or delete
# the line) and the matching module simply never loads.

NODE_ENV=development
PORT=8000

# Comma-separated list of allowed CORS origins.
# Leave empty to allow all origins (fine for local dev, lock down in prod).
CORS_ORIGINS=

# ── MongoDB (optional) ──────────────────────────────── chassis:mongo
# Setting MONGODB_URI enables the Mongo integration.     # chassis:mongo
MONGODB_URI=                                             # chassis:mongo

# ── Auth0 (optional) ────────────────────────────────── chassis:auth0
# Setting BOTH values enables JWT auth on @protectedRoute. # chassis:auth0
AUTH0_DOMAIN=                                            # chassis:auth0
AUTH0_AUDIENCE=                                          # chassis:auth0

# ── Postgres (optional) ─────────────────────────────── chassis:postgres
# Setting DATABASE_URL enables the Postgres + Drizzle integration. # chassis:postgres
DATABASE_URL=                                            # chassis:postgres

# ── SQLite (optional) ───────────────────────────────── chassis:sqlite
# Setting SQLITE_PATH enables the SQLite + Drizzle integration.    # chassis:sqlite
SQLITE_PATH=                                             # chassis:sqlite

# ── Local JWT (optional) ────────────────────────────── chassis:jwt
# Setting JWT_SECRET enables Bearer-token auth on @protectedRoute. # chassis:jwt
JWT_SECRET=                                              # chassis:jwt

# ── Clerk (optional) ────────────────────────────────── chassis:clerk
# Setting CLERK_SECRET_KEY enables Clerk auth on @protectedRoute.  # chassis:clerk
CLERK_SECRET_KEY=                                        # chassis:clerk

# ── Sentry (optional) ──────────────────────────────── chassis:sentry
# Setting SENTRY_DSN enables error reporting to Sentry.  # chassis:sentry
SENTRY_DSN=                                              # chassis:sentry

# ── x402 payments (optional) ────────────────────────── chassis:x402
# Setting X402_PAY_TO enables payment-gated @paidRoute.  # chassis:x402
X402_PAY_TO=                                             # chassis:x402
X402_NETWORK=base-sepolia                                # chassis:x402

# ── MCP server (optional) ───────────────────────────── chassis:mcp
# API base URL the `npm run mcp` stdio server calls into. # chassis:mcp
MCP_API_URL=http://localhost:8000                        # chassis:mcp
